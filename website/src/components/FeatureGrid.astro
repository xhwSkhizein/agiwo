---
const features = [
  {
    title: "Persistent orchestration",
    body: "Use the scheduler for persistent roots, child agents, waiting, wakeups, steering, and controlled cancellation.",
  },
  {
    title: "Traceable execution",
    body: "Persist runs and steps, query traces, and inspect execution after the fact instead of losing the runtime story in logs.",
  },
  {
    title: "Controlled tool surface",
    body: "Combine builtin tools, custom BaseTool implementations, skills, and agent-as-tool composition behind explicit boundaries.",
  },
  {
    title: "Operator path included",
    body: "Run the SDK directly or add the self-hosted Console for sessions, scheduler state, traces, and Docker deployment.",
  },
];
---

<section class="feature-grid">
  {features.map((feature) => (
    <article class="feature-card">
      <h2>{feature.title}</h2>
      <p>{feature.body}</p>
    </article>
  ))}
</section>
