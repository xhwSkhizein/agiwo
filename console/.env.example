# Agiwo Console environment template
#
# Usage:
# 1) Copy this file to .env in the console directory.
# 2) Start API server with env file loading, e.g.:
#    uv run uvicorn server.app:app --reload --env-file .env
#    (or export variables in your shell before starting).

# =============================================================================
# [A] SDK Settings (AGIWO_*) - Core configuration shared by SDK and Console
# =============================================================================
#
# These settings are defined in agiwo/config/settings.py and used by both
# the SDK and Console. Console inherits storage paths from here.

# Root path for all relative paths (default: .agiwo)
AGIWO_ROOT_PATH=.agiwo

# SQLite database path (relative to root_path, or absolute)
# All storages (runs, steps, traces, scheduler states) share this single file.
AGIWO_SQLITE_DB_PATH=agiwo.db

# Trace collection/table name
AGIWO_TRACE_COLLECTION_NAME=agiwo_traces

# Debug and logging
# AGIWO_DEBUG=false
# AGIWO_LOG_LEVEL=INFO
# AGIWO_LOG_JSON=false

# OTLP observability export
# AGIWO_OTLP_ENABLED=false
# AGIWO_OTLP_ENDPOINT=http://localhost:4317
# AGIWO_OTLP_PROTOCOL=grpc

# Skill directories (relative to root_path)
# AGIWO_SKILLS_DIRS=["skills"]

# Builtin tool model defaults (used by tools that internally create a Model)
AGIWO_TOOL_DEFAULT_MODEL_PROVIDER=deepseek
# AGIWO_TOOL_DEFAULT_MODEL_NAME=deepseek-chat
# AGIWO_TOOL_DEFAULT_MODEL_BASE_URL=
# AGIWO_TOOL_DEFAULT_MODEL_API_KEY_ENV_NAME=
# AGIWO_TOOL_DEFAULT_MODEL_TEMPERATURE=0.2
# AGIWO_TOOL_DEFAULT_MODEL_TOP_P=1.0
# AGIWO_TOOL_DEFAULT_MODEL_MAX_TOKENS=2048

# Tool-specific override example
# AGIWO_TOOL_WEB_READER_MODEL_PROVIDER=anthropic
# AGIWO_TOOL_WEB_READER_MODEL_NAME=claude-3-5-haiku-latest
# AGIWO_TOOL_WEB_READER_MODEL_BASE_URL=
# AGIWO_TOOL_WEB_READER_MODEL_API_KEY_ENV_NAME=
# AGIWO_TOOL_WEB_READER_MODEL_TEMPERATURE=0.1
# AGIWO_TOOL_WEB_READER_MODEL_TOP_P=1.0
# AGIWO_TOOL_WEB_READER_MODEL_MAX_TOKENS=2048

# =============================================================================
# [B] Console Server Settings (AGIWO_CONSOLE_*) - Console-specific only
# =============================================================================
#
# These settings are specific to the Console web server.
# Storage paths are inherited from SDK settings above.

# Storage backends (memory | sqlite | mongodb)
# Run/step persistence storage
AGIWO_CONSOLE_RUN_STEP_STORAGE_TYPE=sqlite

# Trace storage ("none" is treated the same as "memory")
AGIWO_CONSOLE_TRACE_STORAGE_TYPE=sqlite

# Metadata storage (agent registry, channel runtime, scheduler state)
# Note: Scheduler state only supports sqlite/memory; mongodb falls back to memory.
AGIWO_CONSOLE_METADATA_STORAGE_TYPE=sqlite

# API server bind host and port
AGIWO_CONSOLE_HOST=0.0.0.0
AGIWO_CONSOLE_PORT=8422

# CORS allowed origins (JSON array string)
AGIWO_CONSOLE_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# MongoDB settings (only used when any *_STORAGE_TYPE=mongodb)
# AGIWO_CONSOLE_MONGODB_URI=mongodb://localhost:27017
# AGIWO_CONSOLE_MONGODB_DB_NAME=agiwo
# AGIWO_CONSOLE_MONGODB_TRACE_COLLECTION=traces

# Feishu channel (SDK 长连接模式，无需公网回调地址)
# AGIWO_CONSOLE_FEISHU_ENABLED=false
# AGIWO_CONSOLE_FEISHU_CHANNEL_INSTANCE_ID=feishu-main
# AGIWO_CONSOLE_FEISHU_API_BASE_URL=https://open.feishu.cn
# AGIWO_CONSOLE_FEISHU_APP_ID=cli_xxx
# AGIWO_CONSOLE_FEISHU_APP_SECRET=xxx
# AGIWO_CONSOLE_FEISHU_VERIFICATION_TOKEN=xxx
# AGIWO_CONSOLE_FEISHU_ENCRYPT_KEY=xxx
# AGIWO_CONSOLE_FEISHU_SDK_LOG_LEVEL=info
# AGIWO_CONSOLE_FEISHU_BOT_OPEN_ID=ou_xxx
# AGIWO_CONSOLE_FEISHU_DEFAULT_AGENT_NAME=agent_name_xxx
# AGIWO_CONSOLE_FEISHU_WHITELIST_OPEN_IDS=["ou_a","ou_b"]
# AGIWO_CONSOLE_FEISHU_DEBOUNCE_MS=3000
# AGIWO_CONSOLE_FEISHU_MAX_BATCH_WINDOW_MS=15000
# AGIWO_CONSOLE_FEISHU_SCHEDULER_WAIT_TIMEOUT=900
# AGIWO_CONSOLE_FEISHU_ACK_REACTION_EMOJI=OK
# AGIWO_CONSOLE_FEISHU_ACK_FALLBACK_TEXT=收到，正在处理。

# =============================================================================
# [C] LLM Provider Credentials - used by agiwo.llm.* providers
# =============================================================================
#
# Console agent runtime resolves credentials from process environment.
# Fill at least the key for providers you actually use in Agent config.

# OpenAI provider
OPENAI_API_KEY=your_openai_api_key_here
# Optional custom endpoint (proxy or OpenAI-compatible gateway)
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek provider
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Anthropic provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# NVIDIA NIM provider
NVIDIA_BUILD_API_KEY=your_nvidia_api_key_here
NVIDIA_BUILD_BASE_URL=https://integrate.api.nvidia.com/v1

# =============================================================================
# [D] Frontend note (Next.js)
# =============================================================================
#
# The web app reads NEXT_PUBLIC_API_URL from console/web/.env.local.
# Example:
# NEXT_PUBLIC_API_URL=http://localhost:8422
