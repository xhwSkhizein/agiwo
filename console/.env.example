# Agiwo Console environment template
#
# Usage:
# 1) Copy this file to .env in the console directory.
# 2) Start API server with env file loading, e.g.:
#    uv run uvicorn server.app:app --reload --env-file .env
#    (or export variables in your shell before starting).

# =============================================================================
# [A] Console Server (AGIWO_CONSOLE_*) - read by console/server/config.py
# =============================================================================

# Storage backend for runs/steps/traces/agent configs.
# Allowed values: sqlite | mongodb
AGIWO_CONSOLE_STORAGE_TYPE=sqlite

# SQLite storage path (used when AGIWO_CONSOLE_STORAGE_TYPE=sqlite).
# Relative path is resolved from current working directory.
AGIWO_CONSOLE_SQLITE_DB_PATH=.agiwo/agiwo.db

# Trace table/collection name for SQLite trace storage.
AGIWO_CONSOLE_SQLITE_TRACE_COLLECTION=agiwo_traces

# MongoDB connection URI (used when AGIWO_CONSOLE_STORAGE_TYPE=mongodb).
# AGIWO_CONSOLE_MONGODB_URI=mongodb://localhost:27017

# MongoDB database name (used when AGIWO_CONSOLE_STORAGE_TYPE=mongodb).
# AGIWO_CONSOLE_MONGODB_DB_NAME=agiwo

# MongoDB collection name for trace documents.
# AGIWO_CONSOLE_MONGODB_TRACE_COLLECTION=traces

# API server bind host and port.
AGIWO_CONSOLE_HOST=0.0.0.0
AGIWO_CONSOLE_PORT=8422

# CORS allowed origins.
# IMPORTANT: must be a JSON array string (not comma-separated plain text).
AGIWO_CONSOLE_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Feishu channel (SDK 长连接模式，无需公网回调地址)
# Turn on Feishu ingress.
# AGIWO_CONSOLE_FEISHU_ENABLED=false
# Channel instance id (for future multi-channel isolation).
# AGIWO_CONSOLE_FEISHU_CHANNEL_INSTANCE_ID=feishu-main
# Feishu OpenAPI base url.
# AGIWO_CONSOLE_FEISHU_API_BASE_URL=https://open.feishu.cn
# Feishu app credentials.
# AGIWO_CONSOLE_FEISHU_APP_ID=cli_xxx
# AGIWO_CONSOLE_FEISHU_APP_SECRET=xxx
# Optional verification token and encrypt key.
# Only needed if your Feishu app enables encrypt/verify.
# AGIWO_CONSOLE_FEISHU_VERIFICATION_TOKEN=xxx
# AGIWO_CONSOLE_FEISHU_ENCRYPT_KEY=xxx
# SDK WS log level: debug | info | warn | error
# AGIWO_CONSOLE_FEISHU_SDK_LOG_LEVEL=info
# Bot open_id for @ mention checks in group chats.
# AGIWO_CONSOLE_FEISHU_BOT_OPEN_ID=ou_xxx
# Default target agent name in Agiwo Agent Registry.
# AGIWO_CONSOLE_FEISHU_DEFAULT_AGENT_NAME=agent_name_xxx
# Whitelist open_ids; JSON array string. Empty means allow all.
# AGIWO_CONSOLE_FEISHU_WHITELIST_OPEN_IDS=["ou_a","ou_b"]
# Debounce and batching controls (milliseconds).
# AGIWO_CONSOLE_FEISHU_DEBOUNCE_MS=3000
# AGIWO_CONSOLE_FEISHU_MAX_BATCH_WINDOW_MS=15000
# Scheduler wait timeout (seconds).
# AGIWO_CONSOLE_FEISHU_SCHEDULER_WAIT_TIMEOUT=900
# Ack behavior.
# AGIWO_CONSOLE_FEISHU_ACK_REACTION_EMOJI=OK
# AGIWO_CONSOLE_FEISHU_ACK_FALLBACK_TEXT=收到，正在处理。

# =============================================================================
# [B] LLM Provider Credentials - used by agiwo.llm.* providers
# =============================================================================
#
# Console agent runtime resolves credentials from process environment.
# Fill at least the key for providers you actually use in Agent config.

# OpenAI provider
OPENAI_API_KEY=your_openai_api_key_here
# Optional custom endpoint (proxy or OpenAI-compatible gateway)
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek provider
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Anthropic provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# NVIDIA NIM provider
NVIDIA_BUILD_API_KEY=your_nvidia_api_key_here
NVIDIA_BUILD_BASE_URL=https://integrate.api.nvidia.com/v1

# =============================================================================
# [C] Optional Runtime/Observability knobs (read by agiwo config/logging)
# =============================================================================

# agiwo settings (prefix: agiwo_). Useful for debugging/export.
# agiwo_debug=false
# agiwo_log_level=INFO
# agiwo_otlp_enabled=false
# agiwo_otlp_endpoint=http://localhost:4317
# agiwo_otlp_protocol=grpc
# agiwo_otlp_headers={"Authorization":"Bearer <token>"}
# agiwo_otlp_sampling_rate=1.0

# Structured logging controls used by agiwo.utils.logging.configure_logging().
# LOG_LEVEL=INFO
# LOG_JSON=false

# Skill directories override (checked by SkillManager).
# Supports JSON array, single path, or comma-separated string.
# agiwo_SKILLS_DIRS=["examples/skills",".agiwo/skills"]
agiwo_SKILLS_DIR=.agiwo/skills

# =============================================================================
# [D] Frontend note (Next.js)
# =============================================================================
#
# The web app reads NEXT_PUBLIC_API_URL from console/web/.env.local.
# Example:
# NEXT_PUBLIC_API_URL=http://localhost:8422
