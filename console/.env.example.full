# Agiwo Full Environment Template (SDK + Console)
#
# This file lists all currently supported SDK and Console environment keys.
# Booleans use true/false. Lists/dicts use JSON.

# =============================================================================
# [A] SDK Core (AGIWO_*)
# =============================================================================

# Enable debug mode.
AGIWO_DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR
AGIWO_LOG_LEVEL=INFO

# Enable JSON logging output.
AGIWO_LOG_JSON=false

# Root path for SDK relative paths.
AGIWO_ROOT_PATH=.agiwo

# Default MongoDB URI for SDK components (empty means unset).
AGIWO_MONGO_URI=

# Default MongoDB database name.
AGIWO_MONGO_DB_NAME=agiwo

# Default SQLite DB path (relative to AGIWO_ROOT_PATH if not absolute).
AGIWO_SQLITE_DB_PATH=agiwo.db

# Vector DB path (relative to AGIWO_ROOT_PATH if not absolute).
AGIWO_VECTOR_DB_PATH=vector_db

# Reserved default session store selector (optional).
AGIWO_DEFAULT_SESSION_STORE=sqlite

# Reserved default trace storage selector (optional).
AGIWO_DEFAULT_TRACE_STORAGE=sqlite

# Trace collection/table name.
AGIWO_TRACE_COLLECTION_NAME=agiwo_traces

# In-memory trace buffer size.
AGIWO_TRACE_BUFFER_SIZE=200

# =============================================================================
# [B] LLM Credentials (canonical provider keys)
# =============================================================================

# OpenAI credentials and endpoint.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-rLWkcet7BmK2fpKZCe617a3dB5854fD8AcD87c0d6690C98d
# Optional custom endpoint (proxy or OpenAI-compatible gateway)
OPENAI_BASE_URL=https://api.edgefn.net/v1

# DeepSeek credentials and endpoint.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# NVIDIA Build credentials and endpoint.
NVIDIA_BUILD_API_KEY=
NVIDIA_BUILD_BASE_URL=https://integrate.api.nvidia.com/v1

# Anthropic credentials and endpoint.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# AWS Bedrock runtime env.
AWS_REGION=us-east-1
AWS_PROFILE=

# Provider default model IDs used by settings.
AGIWO_OPENAI_MODEL_NAME=gpt-codex-5.3
AGIWO_DEEPSEEK_MODEL_NAME=deepseek-reasoner
AGIWO_NVIDIA_MODEL_NAME=moonshotai/kimi-k2.5
AGIWO_ANTHROPIC_MODEL_NAME=claude-3-5-sonnet-20240620

# =============================================================================
# [C] SDK Observability (OTLP)
# =============================================================================

# Enable OTLP exporter.
AGIWO_OTLP_ENABLED=false

# OTLP endpoint, e.g. http://localhost:4317
AGIWO_OTLP_ENDPOINT=

# OTLP protocol: grpc | http
AGIWO_OTLP_PROTOCOL=grpc

# OTLP headers JSON object.
AGIWO_OTLP_HEADERS={}

# Sampling rate in [0,1].
AGIWO_OTLP_SAMPLING_RATE=1.0

# =============================================================================
# [D] SDK Embedding + Memory
# =============================================================================

# Embedding provider: openai | openai-like | local | auto | disabled
AGIWO_EMBEDDING_PROVIDER=openai-like

# Embedding model name.
AGIWO_EMBEDDING_MODEL=BAAI/bge-m3

# Embedding output dimension.
AGIWO_EMBEDDING_DIMENSIONS=1024

# Embedding API key (optional; falls back to OPENAI_API_KEY in SDK logic).
AGIWO_EMBEDDING_API_KEY=sk-tnipmlunlkqnemkacihhfylqwqcougfaxcdintoidhyfxycv

# Embedding base URL (optional; falls back to OPENAI_BASE_URL in SDK logic).
AGIWO_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# Local embedding model path (GGUF).
AGIWO_LOCAL_EMBEDDING_MODEL_PATH=

# Memory chunk token size.
AGIWO_MEMORY_CHUNK_TOKENS=400

# Memory chunk overlap token size.
AGIWO_MEMORY_CHUNK_OVERLAP=80

# Top-K memory retrieval.
AGIWO_MEMORY_TOP_K=5

# Vector retrieval weight.
AGIWO_MEMORY_VECTOR_WEIGHT=0.5

# BM25 retrieval weight.
AGIWO_MEMORY_BM25_WEIGHT=0.5

# Enable temporal decay.
AGIWO_MEMORY_TEMPORAL_DECAY=false

# Temporal decay half-life.
AGIWO_MEMORY_TEMPORAL_DECAY_HALF_LIFE=30.0

# Enable MMR.
AGIWO_MEMORY_MMR_ENABLED=false

# MMR lambda.
AGIWO_MEMORY_MMR_LAMBDA=0.5

# =============================================================================
# [E] SDK Builtin Tool API Config
# =============================================================================

# Web search tool config.
AGIWO_TOOL_WEB_SEARCH_API_BASE_URL=https://oaiaiai.space.z.ai
AGIWO_TOOL_WEB_SEARCH_API_TIMEOUT=30
AGIWO_TOOL_WEB_SEARCH_API_MAX_RESULTS=10
AGIWO_TOOL_WEB_SEARCH_API_RECENCY_DAYS=7
AGIWO_TOOL_WEB_SEARCH_API_MAX_RETRIES=3

# Web reader tool config.
AGIWO_TOOL_WEB_READER_API_TIMEOUT=30
AGIWO_TOOL_WEB_READER_API_MAX_CONTENT_LENGTH=4096

# Builtin tool model defaults.
AGIWO_TOOL_DEFAULT_MODEL_PROVIDER=deepseek
AGIWO_TOOL_DEFAULT_MODEL_NAME=
AGIWO_TOOL_DEFAULT_MODEL_BASE_URL=
AGIWO_TOOL_DEFAULT_MODEL_API_KEY_ENV_NAME=
AGIWO_TOOL_DEFAULT_MODEL_TEMPERATURE=0.2
AGIWO_TOOL_DEFAULT_MODEL_TOP_P=1.0
AGIWO_TOOL_DEFAULT_MODEL_MAX_TOKENS=2048

# VLM tool config.
AGIWO_TOOL_VLM_API_BASE_URL=https://oaiaiai.space.z.ai
AGIWO_TOOL_VLM_API_TIMEOUT=60
AGIWO_TOOL_VLM_IMAGE_FETCH_TIMEOUT=30
AGIWO_TOOL_VLM_API_MAX_RETRIES=3

# Image generation tool config.
AGIWO_TOOL_IMAGE_GEN_API_BASE_URL=https://oaiaiai.space.z.ai
AGIWO_TOOL_IMAGE_GEN_API_TIMEOUT=120
AGIWO_TOOL_IMAGE_GEN_OUTPUT_DIR=./generated_images
AGIWO_TOOL_IMAGE_GEN_DEFAULT_SIZE=1024x1024
AGIWO_TOOL_IMAGE_GEN_MAX_RETRIES=3

# Text-to-speech tool config.
AGIWO_TOOL_TTS_API_BASE_URL=https://oaiaiai.space.z.ai
AGIWO_TOOL_TTS_API_TIMEOUT=60
AGIWO_TOOL_TTS_OUTPUT_DIR=./generated_audio
AGIWO_TOOL_TTS_DEFAULT_VOICE=tongtong
AGIWO_TOOL_TTS_DEFAULT_SPEED=1.0
AGIWO_TOOL_TTS_DEFAULT_VOLUME=1.0

# ASR tool config.
AGIWO_TOOL_ASR_API_BASE_URL=https://oaiaiai.space.z.ai
AGIWO_TOOL_ASR_API_TIMEOUT=60
AGIWO_TOOL_ASR_AUDIO_FETCH_TIMEOUT=30

# Video generation tool config.
AGIWO_TOOL_VIDEO_GEN_API_BASE_URL=https://oaiaiai.space.z.ai
AGIWO_TOOL_VIDEO_GEN_API_TIMEOUT=60
AGIWO_TOOL_VIDEO_GEN_OUTPUT_DIR=./generated_videos
AGIWO_TOOL_VIDEO_GEN_DEFAULT_QUALITY=speed
AGIWO_TOOL_VIDEO_GEN_DEFAULT_WITH_AUDIO=false
AGIWO_TOOL_VIDEO_GEN_DEFAULT_SIZE=1920x1080
AGIWO_TOOL_VIDEO_GEN_DEFAULT_FPS=30
AGIWO_TOOL_VIDEO_GEN_DEFAULT_DURATION=5
AGIWO_TOOL_VIDEO_GEN_POLL_INTERVAL=5
AGIWO_TOOL_VIDEO_GEN_MAX_POLL_COUNT=120
AGIWO_TOOL_VIDEO_GEN_DOWNLOAD_VIDEO=true
AGIWO_TOOL_VIDEO_GEN_DOWNLOAD_TIMEOUT=120

# =============================================================================
# [F] SDK Skills / Scheduler / Compact
# =============================================================================

# Skill directories JSON array.
AGIWO_SKILLS_DIRS=["skills","~/.agent/skills"]

# Enable skill system.
AGIWO_IS_SKILLS_ENABLED=true

# Scheduler pending-event debounce min count.
AGIWO_EVENT_DEBOUNCE_MIN_COUNT=2

# Scheduler pending-event debounce max wait seconds.
AGIWO_EVENT_DEBOUNCE_MAX_WAIT_SECONDS=10.0

# Compact trigger ratio.
AGIWO_COMPACT_THRESHOLD_RATIO=0.9

# Compact model (empty means use agent model).
AGIWO_COMPACT_MODEL=

# Whether compact can be interrupted.
AGIWO_COMPACT_INTERRUPTIBLE=false

# Compact retry count.
AGIWO_COMPACT_RETRY_COUNT=3

# Assistant response after compact.
AGIWO_COMPACT_ASSISTANT_RESPONSE=Understood. I have the context from the summary. Continuing.

# =============================================================================
# [G] Console Core (AGIWO_CONSOLE_*)
# =============================================================================

# API bind host.
AGIWO_CONSOLE_HOST=0.0.0.0

# API bind port.
AGIWO_CONSOLE_PORT=8422

# Run/step storage: memory | sqlite | mongodb
AGIWO_CONSOLE_RUN_STEP_STORAGE_TYPE=sqlite

# Trace storage: none | memory | sqlite | mongodb
# Note: none is treated as memory.
AGIWO_CONSOLE_TRACE_STORAGE_TYPE=sqlite

# Metadata storage: memory | sqlite | mongodb
# Scheduler state supports memory/sqlite only; mongodb falls back to memory.
AGIWO_CONSOLE_METADATA_STORAGE_TYPE=sqlite

# Console MongoDB connection info (used when relevant storage type is mongodb).
# AGIWO_CONSOLE_MONGODB_URI=mongodb://localhost:27017
# AGIWO_CONSOLE_MONGODB_DB_NAME=agiwo
# AGIWO_CONSOLE_MONGODB_TRACE_COLLECTION=traces

# CORS allow list JSON array.
AGIWO_CONSOLE_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# =============================================================================
# [H] Console Default Agent Bootstrap
# =============================================================================

# Bootstrap default agent id.
AGIWO_CONSOLE_DEFAULT_AGENT_ID=Walaha000

# Bootstrap default agent name.
AGIWO_CONSOLE_DEFAULT_AGENT_NAME=Walaha

# Bootstrap default agent description.
AGIWO_CONSOLE_DEFAULT_AGENT_DESCRIPTION=

# Bootstrap default agent model provider.
AGIWO_CONSOLE_DEFAULT_AGENT_MODEL_PROVIDER=openai-compatible

# Bootstrap default agent model name.
AGIWO_CONSOLE_DEFAULT_AGENT_MODEL_NAME=MiniMax-M2.5

# Bootstrap default agent model params JSON object.
AGIWO_CONSOLE_DEFAULT_AGENT_MODEL_PARAMS={"api_key_env_name":"MINIMAX_API_KEY","base_url":"https://api.edgefn.net/v1"}

# Bootstrap default agent system prompt.
AGIWO_CONSOLE_DEFAULT_AGENT_SYSTEM_PROMPT=

# =============================================================================
# [I] Console Feishu Channel
# =============================================================================

# Enable Feishu channel.
AGIWO_CONSOLE_FEISHU_ENABLED=true

# Feishu channel instance id.
AGIWO_CONSOLE_FEISHU_CHANNEL_INSTANCE_ID=feishu-main

# Feishu OpenAPI base URL.
AGIWO_CONSOLE_FEISHU_API_BASE_URL=https://open.feishu.cn

# AGIWO_CONSOLE_FEISHU_ENABLED=true
# AGIWO_CONSOLE_FEISHU_MODE=long_connection
# AGIWO_CONSOLE_FEISHU_APP_ID=cli_a9f6f5c8f1389cb5
# AGIWO_CONSOLE_FEISHU_APP_SECRET=90CNiHj6nb73PpSDNw3P70G3u0TRyIDy
# AGIWO_CONSOLE_FEISHU_BOT_OPEN_ID=ou_92645fd76131b863fd52b4aaf2d30f6c
# AGIWO_CONSOLE_FEISHU_DEFAULT_AGENT_NAME=Walaha
# AGIWO_CONSOLE_FEISHU_WHITELIST_OPEN_IDS=[]
# Feishu app credentials.
AGIWO_CONSOLE_FEISHU_APP_ID=cli_a9f6f5c8f1389cb5
AGIWO_CONSOLE_FEISHU_APP_SECRET=90CNiHj6nb73PpSDNw3P70G3u0TRyIDy

# Feishu verification token (event verification).
# AGIWO_CONSOLE_FEISHU_VERIFICATION_TOKEN=

# Feishu event encrypt key.
# AGIWO_CONSOLE_FEISHU_ENCRYPT_KEY=

# Feishu SDK log level: debug | info | warn | error
AGIWO_CONSOLE_FEISHU_SDK_LOG_LEVEL=info

# Bot Open ID (required for group @ trigger).
AGIWO_CONSOLE_FEISHU_BOT_OPEN_ID=ou_92645fd76131b863fd52b4aaf2d30f6c

# Default agent name used by Feishu channel.
AGIWO_CONSOLE_FEISHU_DEFAULT_AGENT_NAME=Walaha

# Whitelist open ids JSON array (empty means allow all).
AGIWO_CONSOLE_FEISHU_WHITELIST_OPEN_IDS=[]

# Message debounce milliseconds.
AGIWO_CONSOLE_FEISHU_DEBOUNCE_MS=5000

# Maximum message batch window milliseconds.
AGIWO_CONSOLE_FEISHU_MAX_BATCH_WINDOW_MS=15000

# Scheduler wait timeout seconds.
AGIWO_CONSOLE_FEISHU_SCHEDULER_WAIT_TIMEOUT=900

# ACK reaction emoji key.
AGIWO_CONSOLE_FEISHU_ACK_REACTION_EMOJI=Typing

# ACK fallback text when reaction fails.
AGIWO_CONSOLE_FEISHU_ACK_FALLBACK_TEXT=收到，正在处理。
