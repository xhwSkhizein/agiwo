# LLM API Keys
# Copy this file to .env and fill in your real API keys

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# NVIDIA API Key
NVIDIA_BUILD_API_KEY=your_nvidia_api_key_here

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Custom Base URLs (if needed)
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ============================================
# Embedding Configuration
# ============================================
# Provider: openai | openai-like | local | auto | disabled
# AGIWO_EMBEDDING_PROVIDER=auto

# OpenAI Embedding (uses OPENAI_API_KEY by default)
# AGIWO_EMBEDDING_MODEL=text-embedding-3-small
# AGIWO_EMBEDDING_DIMENSIONS=1536

# OpenAI-like Embedding (for SiliconFlow, vLLM, Ollama, etc.)
# AGIWO_EMBEDDING_API_KEY=your_api_key_here
# AGIWO_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# Local Embedding (GGUF model via llama-cpp-python)
# AGIWO_LOCAL_EMBEDDING_MODEL_PATH=~/.agiwo/models/embeddinggemma-300M-Q8_0.gguf
