# Agiwo SDK environment template
#
# Copy to `.env` in the repository root when running the SDK locally.

# Core paths and persistence
AGIWO_ROOT_PATH=.agiwo
AGIWO_SQLITE_DB_PATH=agiwo.db
# AGIWO_MONGO_URI=mongodb://localhost:27017
# AGIWO_MONGO_DB_NAME=agiwo

# Default tool model settings
# Builtin tools that need a Model (currently web_reader) build their own model
# from these defaults unless a tool-specific override is provided.
AGIWO_TOOL_DEFAULT_MODEL_PROVIDER=deepseek
# AGIWO_TOOL_DEFAULT_MODEL_NAME=deepseek-chat
# AGIWO_TOOL_DEFAULT_MODEL_BASE_URL=
# AGIWO_TOOL_DEFAULT_MODEL_API_KEY_ENV_NAME=
# AGIWO_TOOL_DEFAULT_MODEL_TEMPERATURE=0.2
# AGIWO_TOOL_DEFAULT_MODEL_TOP_P=1.0
# AGIWO_TOOL_DEFAULT_MODEL_MAX_TOKENS=2048

# Tool-specific override example for web_reader
# AGIWO_TOOL_WEB_READER_MODEL_PROVIDER=anthropic
# AGIWO_TOOL_WEB_READER_MODEL_NAME=claude-3-5-haiku-latest
# AGIWO_TOOL_WEB_READER_MODEL_BASE_URL=
# AGIWO_TOOL_WEB_READER_MODEL_API_KEY_ENV_NAME=
# AGIWO_TOOL_WEB_READER_MODEL_TEMPERATURE=0.1
# AGIWO_TOOL_WEB_READER_MODEL_TOP_P=1.0
# AGIWO_TOOL_WEB_READER_MODEL_MAX_TOKENS=2048

# Web search
# SERPER_API_KEY=your_serper_api_key_here
# AGIWO_TOOL_WEB_SEARCH_API_BASE_URL=https://google.serper.dev
# AGIWO_TOOL_WEB_SEARCH_API_TIMEOUT=30
# AGIWO_TOOL_WEB_SEARCH_API_MAX_RESULTS=10
# AGIWO_TOOL_WEB_SEARCH_API_RECENCY_DAYS=7

# Provider credentials
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# NVIDIA_BUILD_API_KEY=your_nvidia_api_key_here
# NVIDIA_BUILD_BASE_URL=https://integrate.api.nvidia.com/v1
